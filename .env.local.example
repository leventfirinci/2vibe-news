# 2Vibe News — Environment Variables
# Copy this file to .env.local and fill in values

# AI API Keys (OPTIONAL — app works without them, uses RSS snippets)
# Both are free. Get keys at:

# Gemini: https://aistudio.google.com/apikey (1,000 req/day free)
GEMINI_API_KEY=

# Groq: https://console.groq.com/keys (14,400 req/day free)
GROQ_API_KEY=
